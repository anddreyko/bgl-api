{
    "name": "anddreyko/bgl-api",
    "version": "2.0.0",
    "type": "project",
    "description": "API-gateway backend for project BordGameLog / For records.",
    "license": "proprietary",
    "authors": [
        {
            "name": "anddreyko"
        }
    ],
    "config": {
        "process-timeout": 0,
        "soft-packages": true,
        "sort-packages": true,
        "bump-after-update": true,
        "apcu-autoloader": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "composer": "*"
    },
    "scripts": {
    },
    "extra": {
    }
}
