{
    "name": "anddreyko/bgl-api",
    "version": "2.13.7",
    "type": "project",
    "description": "API-gateway backend for project BordGameLog / For records.",
    "license": "proprietary",
    "authors": [
        {
            "name": "anddreyko",
            "email": "anddreyko@gmail.com"
        }
    ],
    "config": {
        "bin-dir": "vendor-bin/codeception/vendor/bin",
        "process-timeout": 0,
        "soft-packages": true,
        "sort-packages": true,
        "bump-after-update": true,
        "apcu-autoloader": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "php-http/discovery": false
        }
    },
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-filter": "*",
        "ext-mbstring": "*",
        "ext-simplexml": "*",
        "composer": "2.*",
        "devizzent/cebe-php-openapi": "^1.1",
        "doctrine/collections": "^2.6",
        "doctrine/dbal": "^4.3",
        "doctrine/migrations": "^3.9",
        "doctrine/orm": "^3.5",
        "doctrine/persistence": "^4.1",
        "eventsauce/object-hydrator": "^1.8",
        "guzzlehttp/guzzle": "^7.10",
        "laminas/laminas-config-aggregator": "^1.19",
        "lbuchs/webauthn": "^2.2",
        "lcobucci/jwt": "^5.6",
        "league/fractal": "^0.21.0",
        "league/openapi-psr7-validator": "^0.22.0",
        "league/tactician": "^1.1",
        "monolog/monolog": "^3.9",
        "php-di/php-di": "^7.1",
        "psr/clock": "^1.0",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0",
        "ramsey/uuid": "^4.9",
        "sentry/sentry": "^4.22",
        "slim/slim": "^4.15",
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/mime": "^8.0",
        "symfony/resend-mailer": "^8.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "mcustiel/phiremock-client": "^1.0",
        "slim/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Bgl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bgl\\Tests\\": "tests/",
            "Codeception\\": [
                "vendor-bin/codeception/vendor/codeception/codeception/src/Codeception",
                "vendor-bin/codeception/vendor/codeception/lib-asserts/src/Codeception",
                "vendor-bin/codeception/vendor/codeception/stub/src"
            ],
            "Codeception\\Module\\": [
                "vendor-bin/codeception/vendor/codeception/module-cli/src/Codeception/Module"
            ],
            "Rector\\": [
                "vendor-bin/rector/vendor/rector/rector/src",
                "vendor-bin/rector/vendor/rector/rector/rules"
            ],
            "Vasoft\\VersionIncrement\\": "vendor-bin/semver/vendor/voral/version-increment/src"
        }
    },
    "scripts": {
        "bin": "echo 'bin not installed'",
        "post-install-cmd": [
            "@composer bin all install"
        ],
        "scan:api": [
            "@oa:run"
        ],
        "scan:php": [
            "@lp:run",
            "@ps:run",
            "@pd:check"
        ],
        "scan:style": [
            "@rc:run",
            "@cs:fix"
        ],
        "scan:depend": [
            "@cd",
            "@dt:run"
        ],
        "scan:all": [
            "@cd",
            "@scan:php",
            "@dt:run",
            "@scan:api",
            "@test:all"
        ],
        "cs": "vendor-bin/phpcs/vendor/bin/phpcs",
        "cs:fix": "vendor-bin/phpcs/vendor/bin/phpcbf",
        "rc": "vendor-bin/rector/vendor/bin/rector",
        "rc:run": "@rc process --no-progress-bar",
        "lp": "vendor-bin/phplint/vendor/bin/phplint",
        "lp:run": "@lp -c .phplint.yml",
        "ps": "vendor-bin/psalm/vendor/bin/psalm",
        "ps:run": "@ps --no-progress --no-diff --threads=1 -c psalm.xml",
        "ps:clean": "@ps --clear-cache -c psalm.xml",
        "cd": "vendor-bin/composer-dependency/vendor/bin/composer-dependency-analyser",
        "dt": "vendor-bin/deptrac/vendor/bin/deptrac",
        "dt:run": "@dt analyse --config-file=deptrac.yml --cache-file=var/.deptrac.cache --no-progress",
        "in": "APP_ENV=test php -d memory_limit=512M vendor-bin/codeception/vendor/bin/infection",
        "in:run": "@in --min-msi=70 --min-covered-msi=80",
        "in:ps": "APP_ENV=test php -d memory_limit=512M vendor-bin/codeception/vendor/bin/roave-infection-static-analysis-plugin --psalm-config psalm.xml",
        "test": "APP_ENV=test vendor-bin/codeception/vendor/bin/codecept",
        "test:unit": "@test run Unit",
        "test:func": "@test run Functional",
        "test:intg": "@test run Integration",
        "test:web": "@test run Web",
        "test:cli": "@test run Cli",
        "test:smoke": "@test run -g smoke",
        "test:clean": "@test clean",
        "test:build": "@test build",
        "test:coverage": [
            "@test:rebuild",
            "APP_ENV=test XDEBUG_MODE=coverage vendor-bin/codeception/vendor/bin/codecept run Unit,Integration,Functional --coverage --coverage-html"
        ],
        "test:rebuild": [
            "@test:clean",
            "@test:build"
        ],
        "test:all": [
            "@test:rebuild",
            "@test:unit",
            "@test:intg",
            "@test:func",
            "@test:smoke",
            "@test:web -x smoke",
            "@test:cli -x smoke",
            "@in:ps"
        ],
        "pd": "vendor-bin/pdepend/vendor/bin/pdepend",
        "pd:run": "sh -c 'vendor-bin/pdepend/vendor/bin/pdepend --summary-xml=var/pdepend-summary.xml --suffix=php src/ >/dev/null 2>&1 || true'",
        "pd:check": [
            "@pd:run",
            "php bin/pdepend-check.php --ccn=8 --npath=100 --loc=40 --wmc=50"
        ],
        "oa": "vendor/devizzent/cebe-php-openapi/bin/php-openapi",
        "oa:v": "@oa validate --read-json web/openapi.json",
        "oa:run": [
            "php cli/app openapi:export",
            "@oa:v"
        ],
        "bm": "vendor-bin/phpbench/vendor/bin/phpbench",
        "bm:run": "@bm run --report=aggregate",
        "bm:base": "@bm run --tag=baseline --report=aggregate",
        "bm:check": "@bm run --ref=baseline --report=aggregate",
        "vi": "vendor-bin/semver/vendor/bin/vs-version-increment",
        "vi:major": "@vi major",
        "vi:minor": "@vi minor",
        "vi:patch": "@vi patch",
        "vi:list": "@vi --list",
        "vi:debug": "@vi --debug"
    },
    "scripts-descriptions": {
        "scan:php": "Running all scripts with PHP code validation tools",
        "scan:style": "Running clean style tools",
        "scan:depend": "Running all scripts with dependencies validation tools",
        "scan:all": "Running all scripts with all validation tools",
        "cs": "Alias phpcs",
        "cs:fix": "Alias phpcbf",
        "rc": "Alias rector",
        "rc:run": "Check by codestyle rector",
        "lp": "Alias phplint",
        "lp:run": "Check by linting PHP-code",
        "ps": "Alias Psalm",
        "ps:run": "Check by Psalm",
        "ps:clean": "Clean cache Psalm",
        "cd": "Alias composer-dependency-analyser",
        "dt": "Alias deptrac",
        "dt:run": "Run archutecture tests",
        "in": "Alias Infection",
        "in:run": "Check by Infection",
        "in:ps": "Check by Infection with Psalm",
        "test": "Alias Codeception",
        "test:unit": "Run unit tests",
        "test:func": "Run functional tests",
        "test:intg": "Run integration tests",
        "test:web": "Run web-app tests",
        "test:cli": "Run console-app tests",
        "test:smoke": "Clean tests cache",
        "test:clean": "Clean tests cache",
        "test:build": "Build tests helpers",
        "test:rebuild": "Clean cache and build helpers",
        "test:all": "Run all tests",
        "test:coverage": "Show covarege tests",
        "pd": "Alias PDepend",
        "pd:run": "Generate PDepend summary XML",
        "pd:check": "Run PDepend and check complexity thresholds (CCN > 8, NPath > 100, LOC > 40, WMC > 50)",
        "oa": "Alias php-openapi CLI",
        "oa:v": "Validate OpenAPI spec (web/openapi.json) against OpenAPI 3.x schema",
        "oa:run": "Export OpenAPI spec + validate against OpenAPI 3.x schema",
        "bm": "Alias PHPBench",
        "bm:run": "Run benchmarks",
        "bm:base": "Create performance baseline",
        "bm:check": "Assert no performance regression vs baseline",
        "vi": "Alias vs-version-increment, auto-detect version increment based on commit analysis",
        "vi:major": "Increment major version and update CHANGELOG.md",
        "vi:minor": "Increment minor version and update CHANGELOG.md",
        "vi:patch": "Increment patch version and update CHANGELOG.md",
        "vi:list": "Display registered commit types and scopes",
        "vi:debug": "Preview auto-detected changes without applying them"
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false,
            "target-directory": "vendor-bin"
        }
    }
}