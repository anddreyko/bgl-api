<?xml version="1.0" ?>
<ruleset name="PSR-12 Coding Standard">
    <arg value="p"/>
    <arg name="colors"/>
    <arg name="cache" value="./var/.phpcs.cache.json"/>

    <rule ref="PSR12">
        <type>warning</type>
    </rule>

    <file>cli</file>
    <file>config</file>
    <file>src</file>
    <file>web</file>

    <exclude-pattern>web/assets</exclude-pattern>

    <rule ref="Generic.Formatting.SpaceAfterCast">
        <properties>
            <property name="spacing" value="0"/>
        </properties>
    </rule>
</ruleset>
